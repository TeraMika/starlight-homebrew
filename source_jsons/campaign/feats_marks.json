        {
            "name": "Mark of the Prophet",
            "source": "Starlight",
            "page": 0,
            "category": "D",
            "prerequisite": [
                {
                    "exclusiveFeatCategory": ["D"]
                }
            ],
            "entries": [
                "You gain the following benefits.",
                {
                    "type": "entries",
                    "name": "Understanding",
                    "entries": [
                        "When you make a Wisdom ({@skill Insight|XPHB}) or Charisma ({@skill Persuasion|XPHB}) check, you can roll {@dice 1d4} and add the number rolled to the ability check."
                    ]
                },
                {
                    "type": "entries",
                    "name": "Guiding Hand",
                    "entries": [
                        "You always have the {@spell Guidance|Starlight} cantrip prepared.",
                        "When you cast it on another creature, you can increase the bonus by {@dice 1d4}. This increases to {@dice 2d4} at 5th level, {@dice 3d4} at 11th level, and {@dice 4d4} at 17th level. You can use this enhancement once, and regain the ability to use it when you finish a {@variantrule Short Rest|XPHB}."
                    ]
                },
                {
                    "type": "entries",
                    "name": "Spells of the Mark",
                    "entries": [
                        "If you have the Spellcasting or Pact Magic class feature, the spells on the Mark of the Prophet Spells table are added to that feature's spell list.",
                        {
                            "type": "table",
                            "caption": "Mark of the Prophet Spells",
                            "colStyles": [
                                "col-2 text-center",
                                "col-10"
                            ],
                            "colLabels": [
                                "Spell Level",
                                "Spells"
                            ],
                            "rows": [
                                [
                                    "1",
                                    "{@spell Bless|XPHB}, {@spell Guiding Bolt|XPHB}"
                                ],
                                [
                                    "2",
                                    "{@spell Enhance Ability|XPHB}, {@spell Detect Thoughts|XPHB}"
                                ],
                                [
                                    "3",
                                    "{@spell Clairvoyance|XPHB}, {@spell Fly|XPHB}"
                                ],
                                [
                                    "4",
                                    "{@spell Aura of Purity|XPHB}, {@spell Freedom of Movement|XPHB}"
                                ],
                                [
                                    "5",
                                    "{@spell Starlight Sending|Starlight}"
                                ]
                            ]
                        }
                    ]
                }
            ],
            "additionalSpells": [
                {
                    "ability": {
                        "choose": ["int", "wis", "cha"]
                    },
                    "known": {
