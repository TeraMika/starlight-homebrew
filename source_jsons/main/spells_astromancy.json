                            ]
                        },
                        {
                            "type": "item",
                            "name": "Six Matches: Protection",
                            "entries": [
                                "A creature of your choice that you can see within 90 feet gains hit points equal to the total rolled, and a creature you can see within 90 feet gains temporary hit points equal to the total rolled."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Seven Matches: Starlight Blessings",
                            "entries": [
                                "You and any creatures of your choice within 30 feet are blessed: you gain the benefits of the {@spell Bless|XPHB} spell until you complete a {@variantrule Long Rest|XPHB}."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Eight Matches: Personal Alignment",
                            "entries": [
