                            "type": "item",
                            "name": "Ten Matches: Will of Fate",
                            "entries": [
                                "You immediately cast the {@spell Wish|XPHB} spell (no action required). You can duplicate a spell of up to 9th level without incurring the stress described in the spell."
                            ]
