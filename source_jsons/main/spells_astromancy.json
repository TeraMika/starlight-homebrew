        {
            "name": "Celestial Alignment",
            "source": "Starlight",
            "level": 7,
            "school": "D",
            "time": [
                {
                    "number": 1,
                    "unit": "action"
                }
            ],
            "range": {
                "type": "point",
                "distance": {
                    "type": "self"
                }
            },
            "components": {
                "v": true,
                "s": true,
                "m": {
                    "text": "a set of ten engraved constellation tiles, worth 500gp",
                    "cost": 50000
                }
            },
            "duration": [
                {
                    "type": "instant"
                }
            ],
            "entries": [
                "You examine the stars, and attempt to pull their alignment into one that is favourable for you. Roll {@damage 10d10}. The number of dice you get that matches any other dice determines the effect, described below.",
                "{@note For the purpose of this spell, the number of matching dice refers to any die that has the same value as another, and not all matches need to share their value. Rolling 1, 2, 2, 4, 5, 5, 5, 9, 10, 10 would be 7 matches.}",
                {
                    "type": "list",
                    "style": "list-hang-notitle",
                    "items": [
                        {
                            "type": "item",
                            "name": "No Matches",
                            "entries": [
                                "You die."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Two Matches: Luck Sacrifice",
                            "entries": [
                                "Until you complete a {@variantrule Long Rest|XPHB}, you have {@variantrule Disadvantage|XPHB} on all {@variantrule D20 Test|XPHB|D20 Tests}. The nearest creature to you (if multiple creatures are equally distant, you choose) has {@variantrule Advantage|XPHB} on all {@variantrule D20 Test|XPHB|D20 Tests} for the next hour."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Three Matches: Chaos",
                            "entries": [
                                "Whenever a creature rolls a {@variantrule D20 Test|XPHB} within 60 feet of you, it rolls twice and uses the result furthest from 10."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Four Matches: Realignment",
                            "entries": [
                                "You and every creature within 60 feet of you immediately gain the benefit of the {@spell Starlike Skim|Starlight} spell and can immediately use the movement granted by the spell."
                            ]
                        },
                        {
