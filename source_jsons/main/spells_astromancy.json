            "entries": [
                "You create a 30-foot radius sphere of violently-shifting gravity centered on a point you can see within range. Teleportation through the edge of the field is impossible. When the spell is cast, and at the start of each of your turns, choose a flux state from the options below. The effect applies to all creatures within the area.",
                {
                    "type": "list",
                    "style": "list-hang-notitle",
                    "items": [
                        {
                            "type": "item",
                            "name": "Collapse",
                            "entries": [
                                "Creatures in the area must make a Strength saving throw or be pulled 10 feet towards the center and take {@damage 5d10} force damage. On a successful, they take half damage and are not pulled."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Inversion",
                            "entries": [
                                "Creatures in the area must make a Dexterity saving throw or be pulled 30 feet into the air and {@condition Restrained|XPHB}. At the end of their next turn they are pulled into the ground as if they had fallen that distance and the condition ends."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Temporal Distortion",
                            "entries": [
                                "Creatures in the area must make a Wisdom saving throw. On a failed save, they cannot take {@variantrule Reaction|XPHB|Reactions}, and become {@condition Dazed|Starlight}. The effect lasts until you create a different flux state."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Event Horizon",
                            "entries": [
                                "The field becomes challenging to escape. A creature that attempts to leave the field by any means must make a Charisma saving throw or become {@condition Halted|Starlight} until the end of their turn, and the attempt fails. When a creature fails this saving throw, it takes {@damage 3d10} force damage."
                            ]
                        },
                        {
                            "type": "item",
                            "name": "Density",
                            "entries": [
                                "The field becomes difficult terrain. When a creature moves within the area, it takes {@damage 2d10} force damage for every 5 feet it moves."
                            ]
                        }
                    ]
