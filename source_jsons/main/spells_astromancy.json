                            ]
                        },
                        {
                            "type": "item",
                            "name": "Nine Matches: Restoration",
                            "entries": [
                                "All creatures of your choice that you can see regain hit points equal to the total rolled and any conditions of their choice end on them."
                            ]
                        },
